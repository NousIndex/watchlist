# Finnhub (free): https://finnhub.io/register  -> quotes, search, logos, websocket
FINNHUB_API_KEY=your_finnhub_key

# Twelve Data (free, optional): https://twelvedata.com/register
# Chart-candle fallback for US symbols when Yahoo rate-limits.
TWELVEDATA_API_KEY=your_twelvedata_key

# Password gate. Leave unset to disable auth entirely.
APP_PASSWORD=choose_a_password
